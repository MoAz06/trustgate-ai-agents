PORT=8080
PUBLIC_BASE_URL=https://YOUR_CLOUD_RUN_URL

# Fivetran REST fallback/read path.
# Fivetran REST uses HTTP Basic auth with api_key:api_secret.
# Use a Scoped API key from the Fivetran dashboard.
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=

# Optional. If omitted, TrustGate tries GET /v1/connections?limit=1.
FIVETRAN_CONNECTION_ID=

# Optional Vertex/Gemini override. Cloud Run defaults to metadata auth.
VERTEX_PROJECT_ID=
VERTEX_LOCATION=global
VERTEX_MODEL=gemini-3.5-flash

# Optional BigQuery override for the Fivetran-synced demo table.
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET=trustgate_demo
BIGQUERY_TABLE=customers
